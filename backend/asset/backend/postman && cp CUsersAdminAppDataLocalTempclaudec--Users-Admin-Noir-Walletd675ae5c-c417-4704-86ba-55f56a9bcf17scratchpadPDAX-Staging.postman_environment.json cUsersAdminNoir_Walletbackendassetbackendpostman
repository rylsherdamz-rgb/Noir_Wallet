{
  "info": {
    "name": "PDAX Institution API - Staging",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Login",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{pdax_username}}\",\n  \"password\": \"{{pdax_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/pdax-institution/v1/login",
          "host": ["{{base_url}}"],
          "path": ["pdax-institution", "v1", "login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const body = pm.response.json();",
              "",
              "pm.test('Status is 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "if (body.challenge_name) {",
              "    pm.environment.set('mfa_session', body.session);",
              "    console.log('MFA required:', body.challenge_name, '- session saved to {{mfa_session}}');",
              "} else if (body.access_token) {",
              "    pm.environment.set('access_token', body.access_token);",
              "    pm.environment.set('id_token', body.id_token);",
              "    pm.environment.set('refresh_token', body.refresh_token);",
              "    console.log('Authenticated - tokens saved to environment');",
              "} else {",
              "    console.log('Unrecognized response shape:', JSON.stringify(body));",
              "}"
            ]
          }
        }
      ]
    }
  ]
}
