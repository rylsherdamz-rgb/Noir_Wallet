# ── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://noir_user:noir_password@localhost:5432/noir_wallet

# ── Stellar ─────────────────────────────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://stellar-testnet.g.alchemy.com/v2/8bi-1e9YaEqKhk7rC6lEE

# ── Server ──────────────────────────────────────────────────────────────────
ENVIRONMENT=development
API_HOST=0.0.0.0
API_PORT=8080
LOG_LEVEL=info
RUST_LOG=info,noir_backend=debug
REQUEST_TIMEOUT_SECS=30
MAX_REQUEST_BODY_BYTES=65536

# ── Database pool ───────────────────────────────────────────────────────────
DB_MAX_CONNECTIONS=20
DB_MIN_CONNECTIONS=2
DB_CONNECT_TIMEOUT_SECS=10
DB_IDLE_TIMEOUT_SECS=600

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_SECS=60
RATE_LIMIT_MAX_REQUESTS=10

# ── Fee channels ─────────────────────────────────────────────────────────────
CHANNEL_MIN_BALANCE_STROOPS=1000000
CHANNEL_TOPUP_TARGET_STROOPS=10000000

# ── Worker intervals ─────────────────────────────────────────────────────────
SUBMISSION_PROCESS_INTERVAL_SECS=5
CONFIRMATION_POLL_INTERVAL_SECS=2
CHANNEL_BALANCE_CHECK_INTERVAL_SECS=300
CONTRACT_SYNC_INTERVAL_SECS=3600
NOTIFICATION_PRUNE_INTERVAL_SECS=30

# ── PDAX settlement (TSK-203) ──────────────────────────────────────────────
# PDAX_ENVIRONMENT selects which base URL below is used: uat | stage | production
# Stay on uat/stage until Phase 8 review — never commit real keys here.
# Base URLs already include the /api/pdax-api prefix; the login client appends
# /pdax-institution/v1/login on top of that.
PDAX_ENVIRONMENT=uat
PDAX_API_BASE_URL_PRODUCTION=https://services.pdax.ph/api/pdax-api
PDAX_API_BASE_URL_STAGE=https://stage.services.sandbox.pdax.ph/api/pdax-api
PDAX_API_BASE_URL_UAT=https://uat.services.sandbox.pdax.ph/api/pdax-api
PDAX_USERNAME=
PDAX_PASSWORD=
PDAX_API_KEY=
PDAX_API_SECRET=
PDAX_WEBHOOK_SECRET=
# Session cache — written automatically by `cargo run --example pdax_login`
# and refreshed by `cargo run --example pdax_refresh_token`. Leave blank.
PDAX_ACCESS_TOKEN=
PDAX_REFRESH_TOKEN=
PDAX_TOKEN_EXPIRES_AT=
LIQUIDATION_THRESHOLD_STROOPS=500000000
LIQUIDATION_CHECK_INTERVAL_SECS=300
