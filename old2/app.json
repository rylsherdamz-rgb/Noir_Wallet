{
  "expo": {
    "name": "Noir Wallet",
    "slug": "noir-wallet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "scheme": "noirwallet",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noirwallet.app",
      "infoPlist": {
        "NFCReaderUsageDescription": "Noir Wallet uses NFC to link RFID cards and stickers to your wallet, and to process contactless payments."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.noirwallet.app",
      "permissions": [
        "NFC"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "usesNfc": true
          },
          "ios": {
            "usesNfc": true
          }
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "75bdc3c7-0561-4dc4-b9f9-058ca3bf94d2"
      }
    },
    "owner": "3x656"
  }
}
